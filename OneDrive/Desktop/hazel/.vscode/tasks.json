{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build and Run Hazel",
            "type": "shell",
            "command": "${workspaceFolder}\\build.bat",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            }
        }
    ]
}
